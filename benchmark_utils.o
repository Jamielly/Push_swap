#include "push_swap.h"

static void	p_s_n(char *s, int n)
{
	ft_putstr_fd(s, 2);
	ft_putnbr_fd(n, 2);
}

static void	print_ops_counts(t_bench *b)
{
	ft_putstr_fd("[bench] ", 2);
	p_s_n("sa: ", b->sa);
	p_s_n("  sb: ", b->sb);
	p_s_n("  ss: ", b->ss);
	p_s_n("  pa: ", b->pa);
	p_s_n("  pb: ", b->pb);
	ft_putstr_fd("\n[bench] ", 2);
	p_s_n("ra: ", b->ra);
	p_s_n("  rb: ", b->rb);
	p_s_n("  rr: ", b->rr);
	p_s_n("  rra: ", b->rra);
	p_s_n("  rrb: ", b->rrb);
	p_s_n("  rrr: ", b->rrr);
	ft_putstr_fd("\n", 2);
}

void	print_benchmark(void)
{
	t_bench	*b;
	int		i_d;
	int		f_d;

	b = get_bench();
	if (!b->bench_mode)
		return ;
	i_d = (int)(b->disorder * 100);
	f_d = (int)(b->disorder * 10000) % 100;
	ft_putstr_fd("[bench] disorder:  ", 2);
	ft_putnbr_fd(i_d, 2);
	ft_putstr_fd(".", 2);
	if (f_d < 10)
		ft_putstr_fd("0", 2);
	ft_putnbr_fd(f_d, 2);
	ft_putstr_fd("%\n[bench] strategy:  ", 2);
	if (b->strategy_name)
		ft_putstr_fd(b->strategy_name, 2);
	else
		ft_putstr_fd("sorted / none", 2);
	ft_putstr_fd("\n[bench] total_ops: ", 2);
	ft_putnbr_fd(b->total, 2);
	ft_putstr_fd("\n", 2);
	print_ops_counts(b);
}
