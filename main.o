#include "push_swap.h"

static char	*get_strategy(int argc, char **argv)
{
	int		i;
	char	*strategy;

	i = 1;
	strategy = NULL;
	while (i < argc)
	{
		if (ft_strncmp(argv[i], "--bench", 8) == 0)
			get_bench()->bench_mode = 1;
		else if (is_flag(argv[i]))
			strategy = argv[i];
		i++;
	}
	return (strategy);
}

int	main(int argc, char **argv)
{
	t_number	*stack_a;
	t_number	*stack_b;
	char		*strategy;

	if (argc <= 1)
		return (0);
	stack_a = NULL;
	stack_b = NULL;
	strategy = get_strategy(argc, argv);
	parse_input(&stack_a, argv);
	if (!stack_a)
		return (0);
	get_bench()->disorder = compute_disorder(stack_a);
	if (!is_sorted(stack_a))
		execute_strategy(&stack_a, &stack_b, strategy);
	else
		get_bench()->strategy_name = "sorted / none";
	print_benchmark();
	free_stack(&stack_a);
	free_stack(&stack_b);
	return (0);
}
